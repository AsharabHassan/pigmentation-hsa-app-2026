{
  "name": "hsa-pigmentation-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "video:studio": "remotion studio remotion/index.ts",
    "video:score": "node scripts/generate-hsa-score.mjs",
    "video:voiceover": "node --env-file=.env.local --env-file=.env.elevenlabs.local scripts/generate-hsa-voiceover.mjs",
    "video:music": "node --env-file=.env.local --env-file=.env.elevenlabs.local scripts/generate-hsa-music.mjs",
    "video:capture:journey": "node scripts/capture-hsa-journey.mjs",
    "video:slider:still": "remotion still remotion/index.ts HsaPigmentationSlider out/hsa-pigmentation-slider-preview.png --frame=150",
    "video:slider:render": "remotion render remotion/index.ts HsaPigmentationSlider out/hsa-pigmentation-slider-creative-02.mp4 --codec=h264 --crf=18 --audio-bitrate=320k --pixel-format=yuv420p --concurrency=1",
    "video:voiceover:temp": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-temp-voiceover.ps1",
    "video:still": "remotion still remotion/index.ts HsaPigmentationCinematic out/hsa-pigmentation-cinematic-preview.png --frame=1080",
    "video:render": "remotion render remotion/index.ts HsaPigmentationCinematic out/hsa-pigmentation-cinematic-v2.mp4 --codec=h264 --crf=18 --audio-bitrate=320k --pixel-format=yuv420p --concurrency=1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@remotion/captions": "4.0.494",
    "@remotion/cli": "4.0.494",
    "@remotion/media": "4.0.494",
    "@remotion/transitions": "4.0.494",
    "clsx": "^2.1.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.17.0",
    "mediabunny": "1.50.9",
    "motion": "^12.40.0",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remotion": "4.0.494",
    "tailwind-merge": "^3.6.0",
    "zod": "4.3.6",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
