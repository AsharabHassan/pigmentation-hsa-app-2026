# ── Server (never exposed to the browser) ───────────────────────────────────
# Anthropic API key for the Claude Vision pigmentation analysis.
ANTHROPIC_API_KEY=sk-ant-...
# Optional model override (defaults to claude-sonnet-4-6).
ANTHROPIC_MODEL=claude-sonnet-4-6
# GoHighLevel inbound webhook URL that receives qualified leads.
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/...
# Optional — GHL Private Integration for PDF report delivery.
GHL_API_TOKEN=REPLACE
GHL_LOCATION_ID=REPLACE
GHL_REPORT_FIELD_KEY=facial_app_report_pdf

# ── Public (safe to expose) ─────────────────────────────────────────────────
# Booking / "Book Your Free Online Consultation" destination.
NEXT_PUBLIC_BOOKING_URL=https://harleystreetaesthetic.co.uk/london/book
NEXT_PUBLIC_SITE_URL=https://pigmentation.harleystreetaesthetic.co.uk
# Optional Meta Pixel override. The clinic's pixel (823507040655170) is
# hard-coded in lib/meta-pixel.ts; set this only to target a different pixel.
NEXT_PUBLIC_META_PIXEL_ID=823507040655170
