# ── Server (never exposed to the browser) ───────────────────────────────────
# Anthropic API key for the Claude Vision pigmentation analysis.
ANTHROPIC_API_KEY=sk-ant-...
# Optional model override (defaults to claude-sonnet-4-6).
ANTHROPIC_MODEL=claude-sonnet-4-6
# GoHighLevel inbound webhook URL that receives qualified leads.
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/...
# Optional — GHL Private Integration for consented full PDF report delivery.
GHL_API_TOKEN=REPLACE
GHL_LOCATION_ID=REPLACE
GHL_REPORT_FIELD_KEY=facial_app_report_pdf
GHL_REPORT_DELETE_AFTER_FIELD_KEY=facial_app_report_delete_after
# Safety gate for face-containing CRM reports. Keep false until a tested GHL
# workflow permanently deletes the PDF, media item, note and custom-field link
# within 15 days. This app records the deadline but does not perform the purge.
GHL_FULL_REPORT_STORAGE_ENABLED=false

# ── Public (safe to expose) ─────────────────────────────────────────────────
# Booking / "Book Your Free Online Consultation" destination.
NEXT_PUBLIC_BOOKING_URL=https://harleystreetaesthetic.co.uk/london/contact/
NEXT_PUBLIC_SITE_URL=https://pigmentation.harleystreetaesthetic.co.uk
# Keep full-report delivery disabled until the server flag and tested 15-day
# purge workflow are also enabled. The server still enforces its own flag.
NEXT_PUBLIC_GHL_FULL_REPORT_STORAGE_ENABLED=false
# Meta dataset/pixel used by the HSA pigmentation campaign.
NEXT_PUBLIC_META_PIXEL_ID=1849043682301992
