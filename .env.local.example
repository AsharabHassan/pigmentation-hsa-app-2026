# ── Server (never exposed to the browser) ───────────────────────────────────
# Anthropic API key for the Claude Vision pigmentation analysis.
ANTHROPIC_API_KEY=sk-ant-...
# Optional model override (defaults to claude-sonnet-4-6).
ANTHROPIC_MODEL=claude-sonnet-4-6
# GoHighLevel inbound webhook URL that receives qualified leads (contact details
# + written result summary).
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/...
# GHL Private Integration — required for automatic report delivery. With these
# set, every completed analysis uploads the report PDF, writes its URL onto the
# contact and emails the patient their copy. Leave them unset and the app skips
# report delivery silently; the lead webhook above still fires.
GHL_API_TOKEN=REPLACE
GHL_LOCATION_ID=REPLACE
GHL_REPORT_FIELD_KEY=facial_app_report_pdf

# ── Public (safe to expose) ─────────────────────────────────────────────────
# Booking / "Book Your Free Online Consultation" destination.
NEXT_PUBLIC_BOOKING_URL=https://harleystreetaesthetic.co.uk/london/contact/
NEXT_PUBLIC_SITE_URL=https://pigmentation.harleystreetaesthetic.co.uk
# Meta dataset/pixel used by the HSA pigmentation campaign.
NEXT_PUBLIC_META_PIXEL_ID=1849043682301992
